{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "env": {
    "VITE_API_BASE_URL": "",
    "VITE_STELLAR_NETWORK": "MAINNET",
    "VITE_STELLAR_HORIZON_URL": "https://horizon.stellar.org"
  }
}
