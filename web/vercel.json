{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "env": {
    "VITE_API_BASE_URL": "@api-url",
    "VITE_STELLAR_NETWORK": "TESTNET",
    "VITE_STELLAR_HORIZON_URL": "https://horizon-testnet.stellar.org"
  }
}