NODE_ENV=development
PORT=4000
APP_NAME=TrustLoop
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
STORAGE_DRIVER=file
STELLAR_NETWORK=MAINNET
STELLAR_HORIZON_URL=https://horizon.stellar.org
STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
ENABLE_FEE_SPONSORSHIP=true
STELLAR_BASE_FEE=100
STELLAR_SPONSOR_SECRET_KEY=
STELLAR_SPONSOR_PUBLIC_KEY=
STELLAR_CHALLENGE_SECRET_KEY=
STELLAR_WEB_AUTH_DOMAIN=localhost
STELLAR_HOME_DOMAIN=localhost
SESSION_TTL_MINUTES=720
CHALLENGE_TTL_SECONDS=300
SPONSORSHIP_INTENT_TTL_SECONDS=300
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
